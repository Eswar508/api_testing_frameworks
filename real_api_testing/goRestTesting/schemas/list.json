{
  "valid_json":
  {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id","name", "email", "gender", "status"],
  "properties": {
    "status": { "type": "string", "enum": ["active", "inactive"] },
    "id": { "type": "integer" },
    "name": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "gender": { "type": "string", "enum": ["male", "female"] }
  }
  },
  "invalid_fields":
  {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ErrorListSchema",
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": ["field", "message"],
      "properties": {
        "field": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "invalid_json":
  {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ErrorListSchema",
  "type": "object",
    "required": ["message"],
    "properties": {
      "message": {
        "type": "string"
      }
    }
  }
}